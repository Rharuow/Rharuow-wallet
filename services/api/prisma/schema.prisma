generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Roles ----
model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]

  @@map("roles")
}

// ---- Usuários ----
model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  passwordHash    String           @map("password_hash")
  roleId          String           @map("role_id")
  role            Role             @relation(fields: [roleId], references: [id])
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  accounts        Account[]
  costAreas       CostArea[]
  costTypes       CostType[]
  costs           Cost[]
  costRecurrences CostRecurrence[]

  @@map("users")
}

// ---- Conta do usuário na corretora ----
model Account {
  id               String       @id @default(cuid())
  userId           String       @map("user_id")
  brokerIdentifier String       @map("broker_identifier")
  createdAt        DateTime     @default(now()) @map("created_at")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings         Holding[]
  b3Snapshots      B3Snapshot[]

  @@map("accounts")
}

// ---- Ativo (ação, FII, ETF, BDR, etc.) ----
model Asset {
  id       String    @id @default(cuid())
  symbol   String    @unique
  name     String
  type     String    // STOCK | FII | ETF | BDR | FIXED_INCOME
  holdings Holding[]

  @@map("assets")
}

// ---- Posição do usuário em um ativo ----
model Holding {
  id           String        @id @default(cuid())
  accountId    String        @map("account_id")
  assetId      String        @map("asset_id")
  quantity     Decimal
  avgPrice     Decimal       @map("avg_price")
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asset        Asset         @relation(fields: [assetId], references: [id])
  transactions Transaction[]

  @@map("holdings")
}

// ---- Histórico de transações ----
model Transaction {
  id        String   @id @default(cuid())
  holdingId String   @map("holding_id")
  type      String   // BUY | SELL
  quantity  Decimal
  price     Decimal
  date      DateTime
  holding   Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ---- Segmentos / setores das ações (mapeamento EN → PT) ----
model StockSegment {
  id        String   @id @default(cuid())
  nameEn    String   @unique @map("name_en")
  namePt    String   @map("name_pt")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stock_segments")
}

// ---- Snapshot bruto vindo da B3 ----
model B3Snapshot {
  id         String   @id @default(cuid())
  accountId  String   @map("account_id")
  rawPayload Json     @map("raw_payload")
  parsedAt   DateTime @map("parsed_at")
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("b3_snapshots")
}

// ================================================================
// Gestão de Custos Domésticos
// ================================================================

// ---- Área de custo (global ou personalizada por usuário) ----
model CostArea {
  id        String     @id @default(cuid())
  name      String
  // null = área global (padrão do sistema); preenchido = área personalizada do usuário
  userId    String?    @map("user_id")
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  costTypes CostType[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  @@index([userId, name])
  @@map("cost_areas")
}

// ---- Tipo de custo (subcategoria dentro de uma área) ----
model CostType {
  id          String           @id @default(cuid())
  name        String
  areaId      String           @map("area_id")
  userId      String           @map("user_id")
  area        CostArea         @relation(fields: [areaId], references: [id])
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  costs       Cost[]
  recurrences CostRecurrence[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  @@index([areaId, userId, name])
  @@map("cost_types")
}

// ---- Unidade de recorrência ----
enum RecurrenceUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

// ---- Regra de recorrência de um custo ----
model CostRecurrence {
  id               String         @id @default(cuid())
  userId           String         @map("user_id")
  costTypeId       String         @map("cost_type_id")
  amount           Decimal        @db.Decimal(12, 2)
  description      String?
  unit             RecurrenceUnit
  interval         Int
  startDate        DateTime       @map("start_date")
  nextDate         DateTime       @map("next_date")
  // null = indefinido (encerrado apenas pelo usuário via isActive)
  maxOccurrences   Int?           @map("max_occurrences")
  occurrenceCount  Int            @default(0) @map("occurrence_count")
  isActive         Boolean        @default(true) @map("is_active")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  costType         CostType       @relation(fields: [costTypeId], references: [id])
  costs            Cost[]
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  @@map("cost_recurrences")
}

// ---- Registro individual de custo ----
model Cost {
  id           String          @id @default(cuid())
  // userId desnormalizado: evita 3 joins nas queries de período por usuário
  userId       String          @map("user_id")
  costTypeId   String          @map("cost_type_id")
  amount       Decimal         @db.Decimal(12, 2)
  description  String?
  date         DateTime
  // null = custo avulso; preenchido = gerado por regra de recorrência
  recurrenceId String?         @map("recurrence_id")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  costType     CostType        @relation(fields: [costTypeId], references: [id])
  recurrence   CostRecurrence? @relation(fields: [recurrenceId], references: [id])
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  @@index([userId, date])
  @@map("costs")
}
