generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---- Planos de assinatura ----
enum PlanType {
  FREE
  PREMIUM
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

enum WalletPermission {
  READ
  FULL
}

enum NotificationType {
  WALLET_INVITE_SENT
  WALLET_INVITE_ACCEPTED
  WALLET_INVITE_DECLINED
  WALLET_INVITE_REVOKED
}

enum CreditLedgerEntryKind {
  CREDIT
  DEBIT
  REVERSAL
  ADJUSTMENT
}

enum CreditTopupOrderStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum AssetReportAssetType {
  STOCK
  FII
}

enum AssetReportSourceKind {
  AUTO_FOUND
  MANUAL_UPLOAD
}

enum ReportAnalysisRequestMode {
  AUTO_WEB
  MANUAL_UPLOAD
}

enum ReportMode {
  BRAPI_TICKER
  RI_UPLOAD_AI
}

enum ReportAnalysisJobStatus {
  QUEUED
  SEARCHING_REPORT
  VALIDATING_REPORT
  ANALYZING_REPORT
  COMPLETED
  SEARCH_UNAVAILABLE
  FAILED
}

enum ReportSearchCooldownSource {
  AUTO_WEB
}

model Plan {
  id          String   @id @default(cuid())
  name        PlanType @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]

  @@map("plans")
}

// ---- Roles ----
model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]

  @@map("roles")
}

// ---- Usuários ----
model User {
  id                     String              @id @default(cuid())
  email                  String              @unique
  name                   String?
  passwordHash           String              @map("password_hash")
  isActive               Boolean             @default(false) @map("is_active")
  roleId                 String              @map("role_id")
  role                   Role                @relation(fields: [roleId], references: [id])
  planId                 String?             @map("plan_id")
  plan                   Plan?               @relation(fields: [planId], references: [id])
  // null = plano sem expiração (ex: usuário default/admin ou pagante ativo)
  planExpiresAt          DateTime?           @map("plan_expires_at")
  stripeCustomerId       String?             @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?             @unique @map("stripe_subscription_id")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  accounts               Account[]
  costAreas              CostArea[]
  costTypes              CostType[]
  costs                  Cost[]
  costRecurrences        CostRecurrence[]
  incomes                Income[]
  incomeRecurrences      IncomeRecurrence[]
  emailTokens            EmailVerifyToken[]
  passwordResetTokens    PasswordResetToken[]
  walletInvitesSent      WalletInvite[]      @relation("WalletInviteOwner")
  walletInvitesReceived  WalletInvite[]      @relation("WalletInviteGuest")
  walletAccessesOwned    WalletAccess[]      @relation("WalletAccessOwner")
  walletAccessesGranted  WalletAccess[]      @relation("WalletAccessGuest")
  notifications          Notification[]
  creditBalance          UserCreditBalance?
  creditLedgerEntries    CreditLedgerEntry[]
  creditTopupOrders      CreditTopupOrder[]
  assetReportAccesses    UserAssetReportAccess[]
  reportAnalysisJobs     ReportAnalysisJob[]

  @@map("users")
}

model UserCreditBalance {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  balance   Decimal  @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credit_balances")
}

model CreditTopupOrder {
  id                    String                 @id @default(cuid())
  userId                String                 @map("user_id")
  amount                Decimal
  status                CreditTopupOrderStatus @default(PENDING)
  stripeCheckoutSessionId String?              @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId String?                @unique @map("stripe_payment_intent_id")
  metadata              Json?
  paidAt                DateTime?              @map("paid_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries         CreditLedgerEntry[]

  @@index([userId, status, createdAt])
  @@map("credit_topup_orders")
}

model CreditLedgerEntry {
  id           String                @id @default(cuid())
  userId       String                @map("user_id")
  topupOrderId String?               @map("topup_order_id")
  kind         CreditLedgerEntryKind
  amount       Decimal
  balanceAfter Decimal               @map("balance_after")
  description  String?
  metadata     Json?
  createdAt    DateTime              @default(now()) @map("created_at")
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topupOrder   CreditTopupOrder?     @relation(fields: [topupOrderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([topupOrderId])
  @@map("credit_ledger_entries")
}

model AssetReportSource {
  id                  String               @id @default(cuid())
  assetType           AssetReportAssetType @map("asset_type")
  ticker              String
  reportMode          ReportMode           @map("report_mode")
  monthKey            String               @map("month_key")
  sourceKind          AssetReportSourceKind @map("source_kind")
  sourceUrl           String?              @map("source_url")
  storageKey          String?              @map("storage_key")
  originalFileName    String?              @map("original_file_name")
  documentFingerprint String               @map("document_fingerprint")
  metadata            Json?
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  analyses            AssetReportAnalysis[]
  reportJobs          ReportAnalysisJob[]

  @@unique([assetType, ticker, documentFingerprint])
  @@index([assetType, ticker, createdAt])
  @@index([assetType, ticker, reportMode, monthKey])
  @@map("asset_report_sources")
}

model AssetReportAnalysis {
  id            String                @id @default(cuid())
  assetType     AssetReportAssetType  @map("asset_type")
  ticker        String
  reportMode    ReportMode            @map("report_mode")
  monthKey      String                @map("month_key")
  sourceId      String                @map("source_id")
  analysisText  String                @map("analysis_text")
  model         String
  validUntil    DateTime              @map("valid_until")
  metadata      Json?
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  source        AssetReportSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  accesses      UserAssetReportAccess[]
  reportJobs    ReportAnalysisJob[]

  @@unique([assetType, ticker, sourceId])
  @@index([assetType, ticker, validUntil])
  @@index([assetType, ticker, reportMode, monthKey, validUntil])
  @@map("asset_report_analyses")
}

model UserAssetReportAccess {
  id          String              @id @default(cuid())
  userId      String              @map("user_id")
  analysisId  String              @map("analysis_id")
  expiresAt   DateTime            @map("expires_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis    AssetReportAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@unique([userId, analysisId])
  @@index([userId, expiresAt])
  @@index([analysisId, expiresAt])
  @@map("user_asset_report_accesses")
}

model ReportAnalysisJob {
  id             String                    @id @default(cuid())
  userId         String                    @map("user_id")
  assetType      AssetReportAssetType      @map("asset_type")
  ticker         String
  requestMode    ReportAnalysisRequestMode @map("request_mode")
  status         ReportAnalysisJobStatus   @default(QUEUED)
  priceCharged   Decimal?                  @map("price_charged")
  analysisId     String?                   @map("analysis_id")
  sourceId       String?                   @map("source_id")
  failureCode    String?                   @map("failure_code")
  failureMessage String?                   @map("failure_message")
  attemptCount   Int                       @default(0) @map("attempt_count")
  lockedAt       DateTime?                 @map("locked_at")
  startedAt      DateTime?                 @map("started_at")
  finishedAt     DateTime?                 @map("finished_at")
  metadata       Json?
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis       AssetReportAnalysis?      @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  source         AssetReportSource?        @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  cooldowns      ReportSearchCooldown[]

  @@index([userId, createdAt])
  @@index([assetType, ticker, requestMode, createdAt])
  @@index([status, createdAt])
  @@index([analysisId])
  @@index([sourceId])
  @@map("report_analysis_jobs")
}

model ReportSearchCooldown {
  id          String                     @id @default(cuid())
  assetType   AssetReportAssetType       @map("asset_type")
  ticker      String
  source      ReportSearchCooldownSource
  reasonCode  String                     @map("reason_code")
  blockedUntil DateTime                  @map("blocked_until")
  lastJobId   String?                    @map("last_job_id")
  metadata    Json?
  createdAt   DateTime                   @default(now()) @map("created_at")
  updatedAt   DateTime                   @updatedAt @map("updated_at")
  lastJob     ReportAnalysisJob?         @relation(fields: [lastJobId], references: [id], onDelete: SetNull)

  @@unique([assetType, ticker, source])
  @@index([blockedUntil])
  @@index([lastJobId])
  @@map("report_search_cooldowns")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  data      Json?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

// ---- Token de verificação de e-mail ----
model EmailVerifyToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@map("email_verify_tokens")
}

// ---- Token de redefinição de senha ----
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@map("password_reset_tokens")
}

model WalletInvite {
  id        String         @id @default(cuid())
  ownerId   String         @map("owner_id")
  guestEmail String        @map("guest_email")
  guestId   String?        @map("guest_id")
  token     String         @unique
  status    InviteStatus   @default(PENDING)
  expiresAt DateTime       @map("expires_at")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  owner     User           @relation("WalletInviteOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  guest     User?          @relation("WalletInviteGuest", fields: [guestId], references: [id], onDelete: SetNull)
  access    WalletAccess?

  @@index([ownerId, guestEmail, status])
  @@index([guestEmail, status])
  @@index([guestId, status])
  @@map("wallet_invites")
}

model WalletAccess {
  id         String            @id @default(cuid())
  ownerId    String            @map("owner_id")
  guestId    String            @map("guest_id")
  inviteId   String            @unique @map("invite_id")
  permission WalletPermission
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  owner      User              @relation("WalletAccessOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  guest      User              @relation("WalletAccessGuest", fields: [guestId], references: [id], onDelete: Cascade)
  invite     WalletInvite      @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@unique([ownerId, guestId])
  @@index([guestId])
  @@index([ownerId])
  @@map("wallet_accesses")
}

// ---- Conta do usuário na corretora ----
model Account {
  id               String       @id @default(cuid())
  userId           String       @map("user_id")
  brokerIdentifier String       @map("broker_identifier")
  createdAt        DateTime     @default(now()) @map("created_at")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings         Holding[]
  b3Snapshots      B3Snapshot[]

  @@map("accounts")
}

// ---- Ativo (ação, FII, ETF, BDR, etc.) ----
model Asset {
  id       String    @id @default(cuid())
  symbol   String    @unique
  name     String
  type     String    // STOCK | FII | ETF | BDR | FIXED_INCOME
  holdings Holding[]

  @@map("assets")
}

// ---- Posição do usuário em um ativo ----
model Holding {
  id           String        @id @default(cuid())
  accountId    String        @map("account_id")
  assetId      String        @map("asset_id")
  quantity     Decimal
  avgPrice     Decimal       @map("avg_price")
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asset        Asset         @relation(fields: [assetId], references: [id])
  transactions Transaction[]

  @@map("holdings")
}

// ---- Histórico de transações ----
model Transaction {
  id        String   @id @default(cuid())
  holdingId String   @map("holding_id")
  type      String   // BUY | SELL
  quantity  Decimal
  price     Decimal
  date      DateTime
  holding   Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ---- Segmentos / setores das ações (mapeamento EN → PT) ----
model StockSegment {
  id        String   @id @default(cuid())
  nameEn    String   @unique @map("name_en")
  namePt    String   @map("name_pt")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stock_segments")
}

// ---- Snapshot bruto vindo da B3 ----
model B3Snapshot {
  id         String   @id @default(cuid())
  accountId  String   @map("account_id")
  rawPayload Json     @map("raw_payload")
  parsedAt   DateTime @map("parsed_at")
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("b3_snapshots")
}

// ================================================================
// Gestão de Custos Domésticos
// ================================================================

// ---- Área de custo (global ou personalizada por usuário) ----
model CostArea {
  id        String     @id @default(cuid())
  name      String
  // null = área global (padrão do sistema); preenchido = área personalizada do usuário
  userId    String?    @map("user_id")
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  costTypes CostType[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  @@index([userId, name])
  @@map("cost_areas")
}

// ---- Tipo de custo (subcategoria dentro de uma área) ----
model CostType {
  id          String           @id @default(cuid())
  name        String
  areaId      String           @map("area_id")
  userId      String           @map("user_id")
  area        CostArea         @relation(fields: [areaId], references: [id])
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  costs       Cost[]
  recurrences CostRecurrence[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  @@index([areaId, userId, name])
  @@map("cost_types")
}

// ---- Unidade de recorrência ----
enum RecurrenceUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

// ---- Regra de recorrência de um custo ----
model CostRecurrence {
  id               String         @id @default(cuid())
  userId           String         @map("user_id")
  costTypeId       String         @map("cost_type_id")
  amount           Decimal        @db.Decimal(12, 2)
  description      String?
  unit             RecurrenceUnit
  interval         Int
  startDate        DateTime       @map("start_date")
  nextDate         DateTime       @map("next_date")
  // null = indefinido (encerrado apenas pelo usuário via isActive)
  maxOccurrences   Int?           @map("max_occurrences")
  occurrenceCount  Int            @default(0) @map("occurrence_count")
  isActive         Boolean        @default(true) @map("is_active")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  costType         CostType       @relation(fields: [costTypeId], references: [id])
  costs            Cost[]
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  @@map("cost_recurrences")
}

// ---- Registro individual de custo ----
model Cost {
  id           String          @id @default(cuid())
  // userId desnormalizado: evita 3 joins nas queries de período por usuário
  userId       String          @map("user_id")
  costTypeId   String          @map("cost_type_id")
  amount       Decimal         @db.Decimal(12, 2)
  description  String?
  date         DateTime
  // null = custo avulso; preenchido = gerado por regra de recorrência
  recurrenceId String?         @map("recurrence_id")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  costType     CostType        @relation(fields: [costTypeId], references: [id])
  recurrence   CostRecurrence? @relation(fields: [recurrenceId], references: [id])
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  @@index([userId, date])
  @@map("costs")
}

// ================================================================
// Gestão de Entradas (Receitas)
// ================================================================

// ---- Regra de recorrência de uma entrada ----
model IncomeRecurrence {
  id               String         @id @default(cuid())
  userId           String         @map("user_id")
  name             String
  description      String?
  amount           Decimal        @db.Decimal(12, 2)
  unit             RecurrenceUnit
  interval         Int
  startDate        DateTime       @map("start_date")
  nextDate         DateTime       @map("next_date")
  // null = indefinido (encerrado apenas pelo usuário)
  maxOccurrences   Int?           @map("max_occurrences")
  occurrenceCount  Int            @default(0) @map("occurrence_count")
  isActive         Boolean        @default(true) @map("is_active")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes          Income[]
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  @@index([userId])
  @@map("income_recurrences")
}

// ---- Registro individual de entrada ----
model Income {
  id              String             @id @default(cuid())
  userId          String             @map("user_id")
  name            String
  description     String?
  amount          Decimal            @db.Decimal(12, 2)
  date            DateTime
  // null = entrada avulsa; preenchido = gerada por recorrência
  recurrenceId    String?            @map("recurrence_id")
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurrence      IncomeRecurrence?  @relation(fields: [recurrenceId], references: [id])
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  deletedAt       DateTime?          @map("deleted_at")

  @@index([userId, date])
  @@map("incomes")
}
